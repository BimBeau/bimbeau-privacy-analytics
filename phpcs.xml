<?xml version="1.0"?>
<ruleset name="BimBeau Privacy Analytics">
    <description>BimBeau Privacy Analytics coding standards.</description>
    <rule ref="PSR12" />
    <rule ref="Squiz.Commenting.FileComment.SpacingAfterComment" />
    <file>admin</file>
    <file>assets</file>
    <file>includes</file>
    <file>front</file>
    <file>rest</file>
    <file>bimbeau-privacy-analytics.php</file>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/includes/maxmind-db/*</exclude-pattern>
    <exclude-pattern>includes/maxmind-db/*</exclude-pattern>
</ruleset>
