#: src/admin/panels/SettingsPanel.js
msgid "Debug"
msgstr "Depuración"

#: src/admin/panels/SettingsPanel.js
msgid ""
"Enable diagnostic output for troubleshooting tracking events, realtime "
"visitor detection, and REST payloads in the browser console and wp-content/"
"debug.log."
msgstr ""
"Activa la salida de diagnóstico para solucionar eventos de seguimiento, "
"detección de visitantes en tiempo real y cargas REST en la consola del "
"navegador y en wp-content/debug.log."

