msgstr "Διαγραφή όλων των δεδομένων αναλυτικών"

#: src/admin/panels/SettingsPanel.js
msgid "Events configuration"
msgstr "Ρύθμιση συμβάντων"

#: src/admin/panels/SettingsPanel.js
